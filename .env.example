# URL dasar API. Kosongkan di development agar proxy Vite yang dipakai.
VITE_API_BASE_URL=

# Judul aplikasi (tampil di sidebar & title bar)
VITE_APP_NAME=Titik Lapor

# Peta — koordinat awal & level zoom (default: Jakarta Pusat)
VITE_MAP_CENTER_LAT=-6.1754
VITE_MAP_CENTER_LNG=106.8272
VITE_MAP_ZOOM=13
