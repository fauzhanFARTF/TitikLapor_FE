# URL dasar API. Kosongkan di development agar proxy Vite yang dipakai.
VITE_API_BASE_URL=

# Judul aplikasi (tampil di sidebar & title bar)
VITE_APP_NAME=Titik Lapor

# Peta — koordinat awal & level zoom.
# Default menunjuk pusat Kabupaten Tangerang, mengikuti data batas wilayah
# bawaan di backend. Sesuaikan bila Anda mengimpor wilayah lain.
VITE_MAP_CENTER_LAT=-6.1817
VITE_MAP_CENTER_LNG=106.5314
VITE_MAP_ZOOM=11
